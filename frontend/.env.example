# ============================================
# KiteAI Explorer Frontend — Environment
# ============================================

# Blockscout API (backend) — defaults to kitescan.ai if not set
NEXT_PUBLIC_BLOCKSCOUT_API_URL=https://www.kitescan.ai/api/v2
NEXT_PUBLIC_BLOCKSCOUT_GRAPHQL_URL=https://www.kitescan.ai/api/v1/graphql

# Stats microservice (Blockscout stats-service for counters & charts)
NEXT_PUBLIC_STATS_API_URL=https://www.kitescan.ai/stats-service

# Local Archive Node RPC (dashboard uses this directly for real-time data)
NEXT_PUBLIC_RPC_URL=http://localhost:9650/ext/bc/3USaEfTcoUhHxpKXvpAG916UKCUEyjrtkg2hBArBG3JyDP7my/rpc
NEXT_PUBLIC_WS_URL=ws://localhost:9650/ext/bc/3USaEfTcoUhHxpKXvpAG916UKCUEyjrtkg2hBArBG3JyDP7my/ws

# Chain
NEXT_PUBLIC_CHAIN_ID=2366
NEXT_PUBLIC_CHAIN_NAME=KiteAI Mainnet
NEXT_PUBLIC_NATIVE_TOKEN=KITE
NEXT_PUBLIC_NATIVE_TOKEN_DECIMALS=18

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kite Explorer

# WalletConnect (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
