# ============================================
# KiteAI Explorer — Blockscout Backend Config
# ============================================

# === RPC Connection (KiteAI Archive Node) ===
ETHEREUM_JSONRPC_HTTP_URL=http://host.docker.internal:9650/ext/bc/3USaEfTcoUhHxpKXvpAG916UKCUEyjrtkg2hBArBG3JyDP7my/rpc
ETHEREUM_JSONRPC_TRACE_URL=http://host.docker.internal:9650/ext/bc/3USaEfTcoUhHxpKXvpAG916UKCUEyjrtkg2hBArBG3JyDP7my/rpc
ETHEREUM_JSONRPC_WS_URL=ws://host.docker.internal:9650/ext/bc/3USaEfTcoUhHxpKXvpAG916UKCUEyjrtkg2hBArBG3JyDP7my/ws
ETHEREUM_JSONRPC_VARIANT=geth
ETHEREUM_JSONRPC_TRANSPORT=http
ETHEREUM_JSONRPC_DISABLE_ARCHIVE_BALANCES=false

# === Database ===
DATABASE_URL=postgresql://blockscout:kiteExplorer2024@db:5432/blockscout
ECTO_USE_SSL=false
POOL_SIZE=80
POOL_SIZE_API=10

# === Chain Identity ===
CHAIN_ID=2366
NETWORK=KiteAI
SUBNETWORK=KiteAI Mainnet
COIN=KITE
COIN_NAME=KITE

# === Application ===
# IMPORTANT: Generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
PORT=4000
BLOCKSCOUT_HOST=localhost
BLOCKSCOUT_PROTOCOL=http

# === API ===
API_V2_ENABLED=true
API_RATE_LIMIT=50
API_RATE_LIMIT_WHITELISTED_IPS=

# === Mode: API-only (no Blockscout UI) ===
# Blockscout serves ONLY as indexer + API + contract verification.
# All UI is handled by our custom Next.js frontend.
DISABLE_WEBAPP=true
API_V1_READ_METHODS_DISABLED=false
API_V1_WRITE_METHODS_DISABLED=false

# === Features ===
DISABLE_MARKET=true
ACCOUNT_ENABLED=false
ADMIN_PANEL_ENABLED=false
DISABLE_EXCHANGE_RATES=true
SHOW_TXS_CHART=true
TXS_STATS_ENABLED=true

# === Transaction Stats Historian ===
# How many days of tx-per-day history to compile on first startup
TXS_STATS_DAYS_TO_COMPILE_AT_INIT=40
# How many days of coin balance history to keep
COIN_BALANCE_HISTORY_DAYS=90

# === Contract Verification ===
MICROSERVICE_SC_VERIFIER_ENABLED=true
MICROSERVICE_SC_VERIFIER_URL=http://smart-contract-verifier:8050
MICROSERVICE_SC_VERIFIER_TYPE=sc_verifier

# === Indexer ===
INDEXER_DISABLE_PENDING_TRANSACTIONS_FETCHER=true
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=false
INDEXER_DISABLE_ADDRESS_COIN_BALANCE_FETCHER=false
INDEXER_DISABLE_TOKEN_INSTANCE_REALTIME_FETCHER=false
INDEXER_DISABLE_TOKEN_INSTANCE_RETRY_FETCHER=false
INDEXER_DISABLE_TOKEN_INSTANCE_SANITIZE_FETCHER=false
BLOCK_TRANSFORMER=base
INDEXER_MEMORY_LIMIT=4

# === Cache Settings ===
# All values in seconds. Lower = more frequent refresh but heavier DB queries.
CACHE_ADDRESS_WITH_BALANCES_UPDATE_INTERVAL=1800
CACHE_TXS_COUNT_PERIOD=300
CACHE_ADDRESS_COUNT_PERIOD=300
CACHE_BLOCK_COUNT_PERIOD=300
CACHE_TOTAL_GAS_USAGE_PERIOD=300
CACHE_TOTAL_GAS_USAGE_COUNTER_ENABLED=true
# 24h stats cache — controls how often transaction_stats table is queried
CACHE_TRANSACTIONS_24H_STATS_PERIOD=300
# Average block time cache
CACHE_AVERAGE_BLOCK_PERIOD=300

# === Microservices ===
MICROSERVICE_SIG_PROVIDER_URL=http://sig-provider:8050
MICROSERVICE_VISUALIZE_SOL2UML_URL=http://visualizer:8050

# === Redis ===
ACCOUNT_REDIS_URL=redis://redis-db:6379

# === CORS (for custom frontend) ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
